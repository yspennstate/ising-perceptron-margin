  | (x :: xs) =>
    let rec go : (Int × Int × Int × Int) → List (Int × Int × Int × Int) → Bool
      | _, [] => true
      | (_, _, h, e), (y :: ys) =>
        fracEq (h, e, y.1, y.2.1) &&
        fracLt (y.1, y.2.1, y.2.2.1, y.2.2.2) && go y ys
